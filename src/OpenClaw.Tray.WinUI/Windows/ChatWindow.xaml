<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx x:Uid="ChatWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw Chat">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thin popup header -->
        <Grid x:Name="ChatTitleBar" Grid.Row="0" Height="36" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="🦞" FontSize="14"/>
                <TextBlock x:Uid="ChatWindow_TextBlock_29" Text="Chat" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button Click="OnPopout"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatWindowOpenInBrowserToolTip" Content="Open in Browser"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                </Button>
                <Button Click="OnCloseClick"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatWindowCloseToolTip" Content="Close"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Reactor host -->
        <Border x:Name="ChatHost" Grid.Row="1"/>

        <!-- Placeholder when not connected to gateway yet -->
        <StackPanel x:Name="PlaceholderPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Uid="ChatWindow_TextBlock_60" Text="Connect to gateway to start chatting"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</winex:WindowEx>
