<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx x:Uid="ChatWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw Chat">

    <!-- SystemBackdrop is set in code-behind from ChatExplorationState.BackdropMode
         so it tracks the active preset. Do NOT set it here in XAML — the XAML
         value would override the code-behind set on first paint. -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thin popup header -->
        <Grid x:Name="ChatTitleBar" Grid.Row="0" Height="36" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/Square44x44Logo.targetsize-256_altform-unplated.png"
                       Width="18" Height="18" VerticalAlignment="Center"/>
                <TextBlock x:Uid="ChatWindow_TextBlock_29" Text="Chat" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button Click="OnPopout"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="Open in Companion app"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                </Button>
                <Button Click="OnCloseClick"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="Close"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8BB;" FontSize="11"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Reactor host -->
        <Border x:Name="ChatHost" Grid.Row="1"/>

        <!-- WebView2 host: only created/used when "Use standard Gateway Chat interface" is enabled. -->
        <WebView2 x:Name="WebView" Grid.Row="1" Visibility="Collapsed"/>
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Placeholder when not connected to gateway yet -->
        <StackPanel x:Name="PlaceholderPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Uid="ChatWindow_TextBlock_60" Text="Connect to gateway to start chatting"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- WebView2 navigation error panel. -->
        <ScrollViewer x:Name="ErrorPanel" Grid.Row="1" Visibility="Collapsed" Padding="20">
            <StackPanel Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Web Chat Unavailable" Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                           FontFamily="Consolas" Style="{StaticResource CaptionTextBlockStyle}"/>
                <Button Content="Retry" Click="OnRetry" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</winex:WindowEx>
