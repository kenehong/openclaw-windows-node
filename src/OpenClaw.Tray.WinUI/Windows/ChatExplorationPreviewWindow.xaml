<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="OpenClawTray.Windows.ChatExplorationPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    xmlns:explorations="using:OpenClawTray.Controls.ChatExplorations"
    Title="Chat UI preview">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Mirrors tray ChatWindow header exactly so users can compare against
             the real popup. Refresh/Popout are visual placeholders here. The
             pointer handlers turn the header into a drag handle (frameless win). -->
        <Grid x:Name="ChatTitleBar" Grid.Row="0" Height="36" Padding="12,0"
              Background="Transparent"
              PointerPressed="OnTitleBarPointerPressed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image x:Name="HeaderIcon" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="HeaderTitle" Text="Chat" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                <Ellipse x:Name="OnlineDot"
                         Width="8" Height="8" VerticalAlignment="Center"
                         Fill="#107C10"
                         Stroke="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                         StrokeThickness="0.5"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button ToolTipService.ToolTip="Refresh"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                </Button>
                <Button ToolTipService.ToolTip="Open in Browser"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                </Button>
                <Button ToolTipService.ToolTip="Close" Click="OnCloseClick"
                        Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <explorations:ChatExplorationPreview x:Name="Preview" Grid.Row="1" UsesHostBackdrop="True"/>
    </Grid>
</winex:WindowEx>
