<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Uid="TrayMenuWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.TrayMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw Menu"
    Width="320"
    Height="400">

    <!-- Single Fluent flyout surface. Acrylic comes from BackdropHelper (system backdrop)
         + DWM rounded corners on Win11. No inner Border wrapper — that caused double tinting. -->
    <Grid x:Name="RootGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MenuPanel"
                        AutomationProperties.AutomationId="TrayMenuPanel"
                        Padding="4,8" />
        </ScrollViewer>
    </Grid>
</winex:WindowEx>
