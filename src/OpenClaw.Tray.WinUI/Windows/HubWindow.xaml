<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx x:Uid="HubWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.HubWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw"
    MinWidth="750" MinHeight="400">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" PreviewKeyDown="OnRootPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar — Variant C-1m: status pill removed (now lives in
             the overlay pane footer). Title bar carries: hamburger, optional
             back button (visible on Settings), 🦞 + title, search. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Variant C-1m: Back button on the LEFT of the hamburger.
                 Visible only when ContentFrame is on SettingsHostPage. -->
            <Button x:Name="TitleBarBackButton" Grid.Column="0"
                    Click="OnTitleBarBackClick"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Padding="8,4"
                    Margin="-8,0,4,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Back to Home"
                    AutomationProperties.AutomationId="TitleBarBack"
                    ToolTipService.ToolTip="Back to Home">
                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
            </Button>

            <!-- Hamburger (Variant C-1) — toggles overlay nav pane -->
            <Button x:Name="HamburgerButton" Grid.Column="1"
                    Click="OnHamburgerClick"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Padding="8,4"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Open navigation"
                    AutomationProperties.AutomationId="HubHamburgerButton"
                    ToolTipService.ToolTip="Open navigation">
                <FontIcon Glyph="&#xE700;" FontSize="16"/>
            </Button>

            <TextBlock x:Uid="TitleText" Grid.Column="2" x:Name="TitleText" Text="OpenClaw Windows Companion"
                       FontSize="13" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="4,0,0,0"/>

            <!-- Search box -->
            <AutoSuggestBox x:Uid="TitleSearchBox" Grid.Column="3" x:Name="TitleSearchBox"
                            PlaceholderText="Search… (Ctrl+E)"
                            QueryIcon="Find"
                            HorizontalAlignment="Stretch"
                            MinWidth="200" MaxWidth="600"
                            Height="32" VerticalAlignment="Center"
                            Margin="16,0,16,0"
                            TextChanged="OnSearchTextChanged"
                            SuggestionChosen="OnSearchSuggestionChosen"
                            QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,4">
                            <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding Title}" FontSize="12"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>
        </Grid>

        <!-- Main Content — Variant C-1m: LeftMinimal so the pane overlays
             content rather than pushing it. Built-in toggle is hidden because
             the title-bar HamburgerButton drives IsPaneOpen. MenuItems are
             unused (only a hidden Agents host) — the overlay UI lives in
             PaneCustomContent below. -->
        <NavigationView Grid.Row="1"
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            IsPaneOpen="False"
            PaneDisplayMode="LeftMinimal"
            OpenPaneLength="280"
            PaneOpening="OnNavPaneStateChanged"
            PaneClosing="OnNavPaneStateChanged"
            SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <!-- Hidden host for dynamically-rebuilt agent nav items; kept so existing code paths don't NRE. -->
            <NavigationViewItem x:Name="AgentsNavItem" Content="Agents" Visibility="Collapsed" SelectsOnInvoked="False">
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem x:Name="DefaultAgentNavItem" Content="main" Tag="agent:main"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- Variant C-1m overlay pane: Chat preview at top (PaneCustomContent). -->
        <NavigationView.PaneCustomContent>
            <Grid x:Name="OverlayPaneRoot" Padding="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat preview row -->
                <Button x:Name="OverlayChatItem"
                        Grid.Row="0"
                        Click="OnOverlayChatClick"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" BorderThickness="0"
                        Padding="12,10,12,10" Margin="4,4,4,0"
                        CornerRadius="4"
                        AutomationProperties.AutomationId="OverlayChatItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8BD;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Chat"
                                       FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="OverlayChatPreviewText"
                                       Text="Resume conversation"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="2"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </NavigationView.PaneCustomContent>

        <!-- Footer group: divider + Connected row + Settings button.
             PaneFooter is anchored to the bottom of the pane by NavigationView,
             so this group always hugs the bottom regardless of pane height. -->
        <NavigationView.PaneFooter>
            <Grid x:Name="OverlayFooterRoot" Padding="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Divider above footer group -->
                <Border Grid.Row="0" Height="1" Margin="12,0,12,0"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- Connected status row (non-interactive) -->
                <Grid Grid.Row="1" Padding="16,10,16,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="OverlayStatusDot" Grid.Column="0"
                             Width="10" Height="10"
                             VerticalAlignment="Center" Margin="0,0,12,0"
                             Fill="Gray"/>
                    <TextBlock x:Name="OverlayStatusText" Grid.Column="1"
                               Text="Disconnected"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- Settings button (footer) -->
                <Button x:Name="OverlaySettingsItem"
                        Grid.Row="2"
                        Click="OnOverlaySettingsClick"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" BorderThickness="0"
                        Padding="12,10,12,10" Margin="4,0,4,8"
                        CornerRadius="4"
                        AutomationProperties.AutomationId="OverlaySettingsItem">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE713;" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Settings" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </NavigationView.PaneFooter>

        <Frame x:Name="ContentFrame">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition/>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </NavigationView>

    </Grid>
</winex:WindowEx>
