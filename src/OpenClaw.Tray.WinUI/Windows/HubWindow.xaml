<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx x:Uid="HubWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.HubWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw"
    MinWidth="750" MinHeight="400">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" PreviewKeyDown="OnRootPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Hamburger (Variant C-1) — toggles overlay nav pane -->
            <Button x:Name="HamburgerButton" Grid.Column="0"
                    Click="OnHamburgerClick"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Padding="8,4"
                    Margin="-8,0,8,0"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Open navigation"
                    AutomationProperties.AutomationId="HubHamburgerButton"
                    ToolTipService.ToolTip="Open navigation">
                <FontIcon Glyph="&#xE700;" FontSize="16"/>
            </Button>
            <TextBlock x:Uid="TitleText" Grid.Column="1" x:Name="TitleText" Text="OpenClaw Windows Companion"
                       FontSize="13" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"/>

            <!-- Search box -->
            <AutoSuggestBox x:Uid="TitleSearchBox" Grid.Column="2" x:Name="TitleSearchBox"
                            PlaceholderText="Search… (Ctrl+E)"
                            QueryIcon="Find"
                            HorizontalAlignment="Stretch"
                            MinWidth="200" MaxWidth="600"
                            Height="32" VerticalAlignment="Center"
                            Margin="16,0,16,0"
                            TextChanged="OnSearchTextChanged"
                            SuggestionChosen="OnSearchSuggestionChosen"
                            QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,4">
                            <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding Title}" FontSize="12"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>

            <!-- Status indicator on the right -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse x:Name="TitleStatusDot" Width="8" Height="8" VerticalAlignment="Center"
                         Fill="Gray"/>
                <TextBlock x:Uid="TitleStatusText" x:Name="TitleStatusText" Text="Disconnected"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content — Variant C-1: LeftMinimal so the pane overlays
             content rather than pushing it. Built-in toggle is hidden because
             the title-bar HamburgerButton drives IsPaneOpen. -->
        <NavigationView Grid.Row="1"
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            IsPaneOpen="False"
            PaneDisplayMode="LeftMinimal"
            OpenPaneLength="280"
            PaneOpening="OnNavPaneStateChanged"
            PaneClosing="OnNavPaneStateChanged"
            SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <!-- Hidden host for dynamically-rebuilt agent nav items; kept so existing code paths don't NRE. -->
            <NavigationViewItem x:Name="AgentsNavItem" Content="Agents" Visibility="Collapsed" SelectsOnInvoked="False">
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem x:Name="DefaultAgentNavItem" Content="main" Tag="agent:main"/>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition/>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </NavigationView>

    </Grid>
</winex:WindowEx>
