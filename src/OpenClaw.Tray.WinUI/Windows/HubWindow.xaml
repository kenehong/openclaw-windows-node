<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx x:Uid="HubWindow_winexWindowEx_2"
    x:Class="OpenClawTray.Windows.HubWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw"
    MinWidth="750" MinHeight="400">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" PreviewKeyDown="OnRootPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,138,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Variant C-2: Back button shown only when in Settings; returns to Chat. -->
            <Button Grid.Column="0" x:Name="TitleBarBackButton"
                    Width="36" Height="32"
                    Background="Transparent" BorderThickness="0"
                    Padding="0" Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Click="OnTitleBarBackClick"
                    ToolTipService.ToolTip="Back to Home"
                    AutomationProperties.AutomationId="TitleBarBack">
                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
            </Button>

            <!-- Icon + Title -->
            <TextBlock Grid.Column="1" Text="🦞" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Uid="TitleText" Grid.Column="2" x:Name="TitleText" Text="OpenClaw Windows Companion"
                       FontSize="13" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"/>

            <!-- Search box -->
            <AutoSuggestBox x:Uid="TitleSearchBox" Grid.Column="3" x:Name="TitleSearchBox"
                            PlaceholderText="Search… (Ctrl+E)"
                            QueryIcon="Find"
                            HorizontalAlignment="Stretch"
                            MinWidth="200" MaxWidth="600"
                            Height="32" VerticalAlignment="Center"
                            Margin="16,0,16,0"
                            TextChanged="OnSearchTextChanged"
                            SuggestionChosen="OnSearchSuggestionChosen"
                            QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,4">
                            <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding Title}" FontSize="12"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>

            <!-- Variant C-2: overflow button sized + placed to match the system caption buttons (min/max/close).
                 Click reveals a flyout with the full status card + Open Settings. -->
            <Button Grid.Column="4" x:Name="OverflowButton"
                    Width="46" Height="32"
                    Background="Transparent" BorderThickness="0" CornerRadius="0"
                    Padding="0" Margin="0,0,0,0"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    ToolTipService.ToolTip="Status &amp; Settings">
                <FontIcon Glyph="&#xE712;" FontSize="12"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <StackPanel Width="320" Spacing="0">
                            <!-- Status card -->
                            <StackPanel Padding="4,4,4,12" Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Ellipse x:Name="FlyoutStatusDot" Width="10" Height="10" Fill="Gray"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FlyoutStatusHeadline"
                                               Text="Disconnected"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock x:Name="FlyoutStatusSubline"
                                           Text=""
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Button x:Name="FlyoutReconnectButton"
                                        Content="Reconnect"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0"
                                        Click="OnFlyoutReconnectClick"/>
                            </StackPanel>

                            <Border Height="1"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    Margin="0,4,0,4"/>

                            <!-- Settings entry -->
                            <Button x:Name="FlyoutOpenSettingsButton"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,8,6,8"
                                    Click="OnFlyoutOpenSettingsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE713;" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open Settings" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Main Content: a single Frame fills the area below the title bar.
             Variant C-2 has no left rail at the Hub level; Settings reaches its
             own tree via SettingsHostPage which is navigated into MainFrame. -->
        <Frame x:Name="MainFrame" Grid.Row="1">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition/>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</winex:WindowEx>
