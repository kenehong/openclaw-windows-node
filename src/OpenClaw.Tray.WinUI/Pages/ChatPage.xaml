<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar — only "Open in Browser" remains; Reactor surface owns its own chrome -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="OpenInBrowserButton" AutomationProperties.AutomationId="ChatOpenInBrowserButton"
                        Width="36" Height="36" Padding="0"
                        Click="OnPopout">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatPageOpenInBrowserToolTip" Content="Open in Browser"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Reactor host: native chat surface mounts its tree into this Border -->
        <Border x:Name="ChatHost" Grid.Row="1"/>

        <!-- Disconnected placeholder (shown when no provider yet) -->
        <StackPanel x:Name="PlaceholderPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Uid="ChatPage_TextBlock_53" Text="Connect to gateway to start chatting"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
