<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:OpenClawTray.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hub-specific toolbar (kept above ChatSurface; hidden by default) -->
        <Border Grid.Row="0"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="HomeButton" AutomationProperties.AutomationId="ChatHomeButton"
                        ToolTipService.ToolTip="Home" Width="36" Height="36" Padding="0"
                        Click="OnHome">
                    <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                </Button>
                <Button x:Name="RefreshButton" AutomationProperties.AutomationId="ChatRefreshButton"
                        ToolTipService.ToolTip="Refresh" Width="36" Height="36" Padding="0"
                        Click="OnRefresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button x:Name="OpenInBrowserButton" AutomationProperties.AutomationId="ChatOpenInBrowserButton"
                        ToolTipService.ToolTip="Open in Browser" Width="36" Height="36" Padding="0"
                        Click="OnPopout">
                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                </Button>
                <Button x:Name="DevToolsButton" AutomationProperties.AutomationId="ChatDevToolsButton"
                        ToolTipService.ToolTip="Developer Tools" Width="36" Height="36" Padding="0"
                        Click="OnDevTools">
                    <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Shared chat surface (native chrome + WebView2 + injection/relay) -->
        <controls:ChatSurface x:Name="Surface" Grid.Row="1" Margin="8"/>
    </Grid>
</Page>
