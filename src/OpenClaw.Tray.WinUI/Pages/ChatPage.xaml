<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:OpenClawTray.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- WebView2 toolbar (Hub-specific actions, kept above ChatShell) -->
        <Border Grid.Row="0"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="HomeButton" AutomationProperties.AutomationId="ChatHomeButton"
                        ToolTipService.ToolTip="Home" Width="36" Height="36" Padding="0"
                        Click="OnHome">
                    <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                </Button>
                <Button x:Name="RefreshButton" AutomationProperties.AutomationId="ChatRefreshButton"
                        ToolTipService.ToolTip="Refresh" Width="36" Height="36" Padding="0"
                        Click="OnRefresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button x:Name="OpenInBrowserButton" AutomationProperties.AutomationId="ChatOpenInBrowserButton"
                        ToolTipService.ToolTip="Open in Browser" Width="36" Height="36" Padding="0"
                        Click="OnPopout">
                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                </Button>
                <Button x:Name="DevToolsButton" AutomationProperties.AutomationId="ChatDevToolsButton"
                        ToolTipService.ToolTip="Developer Tools" Width="36" Height="36" Padding="0"
                        Click="OnDevTools">
                    <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Native ChatShell chrome wraps the WebView2 thread -->
        <controls:ChatShell x:Name="Shell" Grid.Row="1" IsComposerVisible="True" IsHeaderVisible="False" Margin="8">
            <controls:ChatShell.ThreadContent>
                <Grid>
                    <!-- WebView2 (gateway-served chat UI; brings its own composer) -->
                    <WebView2 x:Name="WebView" Visibility="Collapsed"/>

                    <!-- Loading -->
                    <ProgressRing x:Name="LoadingRing" IsActive="False"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Placeholder (shown when not connected) -->
                    <StackPanel x:Name="PlaceholderPanel"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                        <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Connect to gateway to start chatting"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="WebView2 chat will load here once a gateway connection is established."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                    </StackPanel>

                    <!-- Error -->
                    <ScrollViewer x:Name="ErrorPanel" Visibility="Collapsed" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Web Chat Unavailable" Style="{StaticResource SubtitleTextBlockStyle}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            <TextBlock x:Name="ErrorText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                       FontFamily="Consolas" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <Button Content="Open in Browser Instead" Click="OnPopout" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </controls:ChatShell.ThreadContent>
        </controls:ChatShell>
    </Grid>
</Page>
