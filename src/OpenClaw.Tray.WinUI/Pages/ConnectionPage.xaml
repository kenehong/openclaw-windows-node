<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="ConnectionPage_TextBlock_10" Text="🔗 Connection" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Uid="ConnectionPage_TextBlock_11" Text="Manage your gateway connection."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

            <!-- ═══ Auth Error ═══ -->
            <InfoBar x:Uid="AuthErrorBar" x:Name="AuthErrorBar" Title="Connection Error"
                     Severity="Error" IsOpen="False" IsClosable="True"
                     Margin="0,0,0,0"/>

            <!-- ═══ Section 1: Status Card ═══ -->
            <Border x:Name="StatusCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <!-- Row 1: Status + Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Ellipse x:Name="StatusDot" Width="12" Height="12" VerticalAlignment="Center" Fill="Gray"/>
                            <TextBlock x:Uid="StatusText" x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                        <Button x:Uid="ReconnectButton" x:Name="ReconnectButton" Grid.Column="1" Content="Reconnect"
                                VerticalAlignment="Center" Click="OnReconnect" IsEnabled="False" Margin="0,0,8,0"/>
                        <Button x:Name="DisconnectButton" Grid.Column="2" Content="Disconnect"
                                VerticalAlignment="Center" Click="OnDisconnect" Visibility="Collapsed"/>
                    </Grid>
                    <!-- Row 2: Gateway details -->
                    <TextBlock x:Name="GatewayDetailText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <!-- Row 3: URL + auth mode -->
                    <TextBlock x:Name="GatewayUrlDetail"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <!-- Role Status Rows -->
                    <StackPanel Margin="0,4,0,0" Spacing="6">
                        <!-- Operator row -->
                        <Border x:Name="OperatorAccentCard"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderThickness="3,0,0,0" BorderBrush="Gray"
                                CornerRadius="4" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🖥️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="Operator" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" Width="60"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Ellipse x:Name="OperatorStatusDot" Width="10" Height="10" VerticalAlignment="Center" Fill="Gray"/>
                                    <TextBlock x:Name="OperatorStatusLabel" Text="Off" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="OperatorDetailText" Grid.Column="3" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- Node row -->
                        <Border x:Name="NodeAccentCard"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderThickness="3,0,0,0" BorderBrush="Gray"
                                CornerRadius="4" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📡" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="Node" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" Width="60"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Ellipse x:Name="NodeStatusDot" Width="10" Height="10" VerticalAlignment="Center" Fill="Gray"/>
                                    <TextBlock x:Name="NodeStatusLabel" Text="Off" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="NodeDetailText" Grid.Column="3" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <ToggleSwitch x:Name="NodeModeToggle" Grid.Column="4"
                                              VerticalAlignment="Center" Margin="8,0,0,0"
                                              MinWidth="0" MinHeight="0"
                                              Toggled="OnNodeModeToggled"
                                              ToolTipService.ToolTip="Enable/disable Node Mode"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Row 5: Pairing guidance (shown when awaiting approval) -->
                    <Border x:Name="PairingGuidanceCard" Visibility="Collapsed"
                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                            CornerRadius="6" Padding="12" Margin="0,4,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="PairingGuidanceText" TextWrapping="Wrap"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Run this command on the gateway host to approve:"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PairingApproveCommandText" Grid.Column="0"
                                           IsTextSelectionEnabled="True" FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <Button x:Name="CopyApproveCommandButton" Grid.Column="1" Content="Copy"
                                        Click="OnCopyApproveCommand" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button x:Name="ReconnectAfterApprovalButton" Content="Connect (once approved)"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="OnReconnectAfterApproval"/>
                                <Button Content="Disconnect" Click="OnDisconnect"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Connection attempts (shown when connecting, fixed height to avoid layout shift) -->
                    <TextBlock x:Name="ConnectionAttemptsText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MinHeight="16"
                               Opacity="0"/>
                </StackPanel>
            </Border>

            <!-- ═══ Section 1.5: Pending Device Pairing ═══ -->
            <Border x:Name="DevicePairingCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="📋 Pending Device Pairing" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Devices waiting for approval to connect to this gateway."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel x:Name="DevicePairingListPanel" Spacing="6"/>
                </StackPanel>
            </Border>

            <!-- ═══ Section 1.6: Pending Operator/Node Pairing ═══ -->
            <!-- Moved here from the legacy NodesPage so all pairing approvals live
                 in one place on the Connection page (closer to the rest of the
                 pairing/credential UX). Visible only when the gateway reports
                 pending node-pair requests. -->
            <Border x:Name="NodePairingCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="ConnectionPage_NodePairing_Title"
                               Text="🔗 Pending Operator/Node Pairing"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="ConnectionPage_NodePairing_Subtitle"
                               Text="Operators and Windows nodes waiting for approval to connect to this gateway."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel x:Name="NodePairingListPanel" Spacing="6"/>
                </StackPanel>
            </Border>

            <!-- ═══ Connection Methods (Tabbed) ═══ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
            <Pivot x:Name="ConnectionPivot">
                <PivotItem>
                    <PivotItem.Header>
                        <TextBlock Text="🔑 Setup Code" FontSize="13"/>
                    </PivotItem.Header>
                    <StackPanel Spacing="8" Padding="0,12,0,0">
                        <TextBlock x:Uid="ConnectionPage_TextBlock_129" Text="Paste a setup code from openclaw qr"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Uid="SetupCodeTextBox" x:Name="SetupCodeTextBox" Grid.Column="0"
                                     PlaceholderText="Paste setup code here…" TextChanged="OnSetupCodeTextChanged"/>
                            <Button x:Uid="ApplySetupCodeButton" x:Name="ApplySetupCodeButton" Grid.Column="1" Content="Apply"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="OnApplySetupCode" VerticalAlignment="Bottom"/>
                        </Grid>
                        <!-- Decoded preview (shown after pasting) -->
                        <StackPanel x:Name="SetupCodePreviewPanel" Spacing="4" Visibility="Collapsed">
                            <TextBlock x:Name="SetupCodePreviewUrl"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="SetupCodePreviewToken"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="SetupCodeResultText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </PivotItem>

                <PivotItem>
                    <PivotItem.Header>
                        <TextBlock Text="📡 Recent Gateways" FontSize="13"/>
                    </PivotItem.Header>
                    <StackPanel Spacing="8" Padding="0,12,0,0">
                        <TextBlock x:Name="RecentGatewaysEmptyText" Text="No saved gateways yet."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                        <StackPanel x:Name="RecentGatewayListPanel" Spacing="6"/>
                    </StackPanel>
                </PivotItem>

                <PivotItem>
                    <PivotItem.Header>
                        <TextBlock Text="🔗 Direct Connect" FontSize="13"/>
                    </PivotItem.Header>
                    <StackPanel Spacing="6" Padding="0,12,0,0">
                        <TextBlock Text="Connect with a gateway URL and shared token."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBox x:Name="GatewayUrlTextBox" Header="Gateway URL"
                                 PlaceholderText="ws://localhost:18790" Text="ws://localhost:18790"/>
                        <TextBox x:Name="TokenTextBox" Header="Token"
                                 PlaceholderText="Shared gateway token"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DirectConnectResultText" Grid.Column="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Connect" Style="{ThemeResource AccentButtonStyle}" Click="OnDirectConnect"/>
                        </Grid>
                    </StackPanel>
                </PivotItem>
            </Pivot>
            </Border>

            <!-- ═══ SSH Tunnel ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      IsExpanded="False">
                <Expander.Header>
                    <TextBlock Text="🔒 SSH Tunnel" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Expander.Header>
                <StackPanel Spacing="8" Padding="4">
                    <ToggleSwitch x:Uid="SshToggle" x:Name="SshToggle" Header="Enable SSH Tunnel"
                                  Toggled="OnSshToggled" MinWidth="0"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Uid="SshUserBox" x:Name="SshUserBox" Grid.Column="0" Header="SSH User" PlaceholderText="user"/>
                        <TextBox x:Uid="SshHostBox" x:Name="SshHostBox" Grid.Column="1" Header="SSH Host" PlaceholderText="machine-name"/>
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Uid="SshRemotePortBox" x:Name="SshRemotePortBox" Grid.Column="0" Header="Remote Port" PlaceholderText="18789"/>
                        <TextBox x:Uid="SshLocalPortBox" x:Name="SshLocalPortBox" Grid.Column="1" Header="Local Port" PlaceholderText="18789"/>
                    </Grid>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
