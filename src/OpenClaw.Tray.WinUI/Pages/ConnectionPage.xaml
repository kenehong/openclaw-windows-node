<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock Text="🔗 Connection" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Gateway endpoint used by both the operator client and node service."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

            <!-- Status -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" VerticalAlignment="Center" Fill="Gray"/>
                        <TextBlock x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusDetail"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Gateway URL -->
            <TextBox x:Name="GatewayUrlTextBox" Header="Gateway URL"
                     PlaceholderText="ws://localhost:18789 or https://host.tailnet.ts.net"/>

            <!-- Token -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="TokenTextBox" Header="Token"
                         PlaceholderText="Your API token" Width="350"/>
                <Button x:Name="TestButton" Content="Test" VerticalAlignment="Bottom"
                        Click="OnTestConnection"/>
            </StackPanel>
            <TextBlock x:Name="TestResultText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- SSH Tunnel -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="SSH Tunnel" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4">
                    <ToggleSwitch x:Name="SshToggle" Header="Connect through SSH tunnel"
                                  Toggled="OnSshToggled"/>
                    <StackPanel x:Name="SshDetailsPanel" Spacing="8" Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshUserBox" Grid.Column="0" Header="SSH User" PlaceholderText="user"/>
                            <TextBox x:Name="SshHostBox" Grid.Column="1" Header="SSH Host" PlaceholderText="machine-name"/>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshRemotePortBox" Grid.Column="0" Header="Remote Port" PlaceholderText="18789"/>
                            <TextBox x:Name="SshLocalPortBox" Grid.Column="1" Header="Local Port" PlaceholderText="18789"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Gateway Discovery -->
            <Button x:Name="ScanButton" Click="OnScanForGateways">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE966;" FontSize="14"/>
                    <TextBlock Text="Scan for gateways on network"/>
                </StackPanel>
            </Button>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Save" Style="{ThemeResource AccentButtonStyle}" Click="OnSave"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
