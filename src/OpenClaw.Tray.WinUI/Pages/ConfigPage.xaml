<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="24,24,24,12" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Gateway Config" Style="{StaticResource TitleTextBlockStyle}"/>
                <Button x:Name="RefreshButton" Content="↻ Refresh" Click="OnRefresh" VerticalAlignment="Center"
                        Padding="8,4" FontSize="12"/>
            </StackPanel>
            <InfoBar x:Name="ConnectionWarning" Title="Not Connected" 
                     Message="Connect to gateway to view live configuration" 
                     Severity="Warning" IsOpen="True" IsClosable="False" Visibility="Collapsed"/>
            <TextBlock x:Name="ConfigPathText" Text="" 
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Main content: TreeView + Detail -->
        <Grid Grid.Row="1" Padding="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: TreeView -->
            <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,12,0">
                <TreeView x:Name="ConfigTree" 
                          SelectionMode="Single"
                          ItemInvoked="OnTreeItemInvoked"
                          Padding="4">
                </TreeView>
            </Border>

            <!-- Right: Detail Panel -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Detail Header -->
                    <StackPanel Grid.Row="0" Padding="16,12" Spacing="4"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                        <TextBlock x:Name="DetailPath" Text="Select a config key" 
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="DetailType" Text="" 
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Detail Content -->
                    <ScrollViewer Grid.Row="1" Padding="16,8">
                        <StackPanel x:Name="DetailPanel" Spacing="8">
                            <TextBlock x:Name="DetailPlaceholder" 
                                       Text="Click a config key in the tree to view its details."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Padding="24,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" 
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Border>
    </Grid>
</Page>
