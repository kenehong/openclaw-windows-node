<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.UsagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock Text="📊 Usage &amp; Cost" Style="{StaticResource TitleTextBlockStyle}"/>

            <InfoBar x:Name="ConnectionWarning" Title="Not Connected"
                     Message="Connect to gateway to see live data"
                     Severity="Warning" IsOpen="True" IsClosable="False" Visibility="Collapsed"/>

            <!-- Big number: Total Cost -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="Total Cost" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalCostText" Text="$2.41" FontSize="28" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Stats row: 3 cards side by side -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinWidth="150">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Requests" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="RequestCountText" Text="142" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinWidth="150">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Tokens" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TokenCountText" Text="284.5K" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinWidth="150">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Providers" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ProviderCountText" Text="3" FontSize="28" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Time period buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="Period7DaysButton" Content="7 Days" Click="OnPeriod7Days"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button x:Name="Period30DaysButton" Content="30 Days" Click="OnPeriod30Days"/>
            </StackPanel>

            <!-- Provider Breakdown -->
            <TextBlock Text="Provider Breakdown" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>
            <ListView x:Name="ProviderListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Requests}" Margin="16,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Tokens}" Margin="16,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Cost}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Daily Cost -->
            <TextBlock Text="Daily Cost" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>
            <ListView x:Name="DailyListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Date}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Cost}" FontWeight="SemiBold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
