<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.Library.Cat06EmbedsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="980" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="6. Rich embeds (webchat)" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Canvas / A2UI / hosted embeds." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border CornerRadius="10" Padding="8,2" Background="#3328A050"><TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33DC781E"><TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33648CB4"><TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/></Border>
                </StackPanel>
            </StackPanel>
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="6.1 [embed ref=...]" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Hosted canvas document." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Margin="8,2,40,2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
  <StackPanel>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" Padding="10,6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="🖼" FontSize="13"/>
        <TextBlock Text="Canvas: design v3" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Text="· cv_123" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
    <Border Height="160" Background="#FF2A2A2A">
      <TextBlock Text="(canvas content rendered in webchat only)" FontSize="11" Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Trade-off — native chat avoids WebView2 in M1; webchat-only today." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
