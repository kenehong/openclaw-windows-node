  <StackPanel>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" Padding="10,6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="🖼" FontSize="13"/>
        <TextBlock Text="Canvas: design v3" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Text="· cv_123" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
    <Border Height="160" Background="#FF2A2A2A">
      <TextBlock Text="(canvas content rendered in webchat only)" FontSize="11" Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Large — full A2UI host in tray would be a major workstream." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
