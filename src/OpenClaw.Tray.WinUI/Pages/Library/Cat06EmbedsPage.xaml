        <TextBlock Text="Canvas: design v3" FontWeight="SemiBold" FontSize="12"/>
        <TextBlock Text="· cv_123" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
    <Border Height="160" Background="#FF2A2A2A">
      <TextBlock Text="(canvas content rendered in webchat only)" FontSize="11" Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
