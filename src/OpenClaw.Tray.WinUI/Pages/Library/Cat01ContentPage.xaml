<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.Library.Cat01ContentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="980" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="1. Basic content" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Plain text, Markdown, math, emoji, silence, streaming." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border CornerRadius="10" Padding="8,2" Background="#3328A050"><TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33DC781E"><TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33648CB4"><TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/></Border>
                </StackPanel>
            </StackPanel>
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.1 Plain text" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="User and assistant message bubbles." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#3328A050">
        <TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <StackPanel Spacing="4">
<Grid HorizontalAlignment="Right" Margin="40,4,8,4" MaxWidth="640">
  <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10" Padding="12,8">
    <TextBlock FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="White" xml:space="preserve">What's the difference between StaticResource and ThemeResource?</TextBlock>
  </Border>
</Grid>
<Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
  <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="12,8">
    <StackPanel Spacing="4">
      <TextBlock FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap" IsTextSelectionEnabled="True" xml:space="preserve">StaticResource resolves once at load time. ThemeResource re-resolves whenever the theme changes (Light/Dark/HighContrast).</TextBlock>
      
    </StackPanel>
  </Border>
</Grid>
</StackPanel>
    </Border>
    
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.2 Markdown rich" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Headers, bold/italic, lists, quotes, tables, dividers, links." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33DC781E">
        <TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
  <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="14,10">
    <StackPanel Spacing="8">
      <TextBlock Text="Project status" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock TextWrapping="Wrap"><Run FontWeight="Bold">Bold text</Run><Run Text=" and "/><Run FontStyle="Italic">italic</Run><Run Text=" and "/><Run FontFamily="Consolas" Text="inline_code()"/><Run Text="."/></TextBlock>
      <StackPanel Spacing="2">
        <TextBlock Text="• First item" FontSize="13"/>
        <TextBlock Text="• Second item with details" FontSize="13"/>
        <TextBlock Text="• Third item" FontSize="13"/>
      </StackPanel>
      <Border BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="3,0,0,0" Padding="10,4,0,4">
        <TextBlock Text="A relevant quotation from the source." FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </Border>
      <Border BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{ThemeResource SubtleFillColorTertiaryBrush}" Padding="8,4"><TextBlock Text="Header" FontWeight="SemiBold" FontSize="12"/></Border>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="API call" Padding="8,4" FontSize="12"/>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="320 ms" Padding="8,4" FontSize="12"/>
          <TextBlock Grid.Row="1" Grid.Column="2" Text="OK" Padding="8,4" FontSize="12" Foreground="#FF28A050"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="DB query" Padding="8,4" FontSize="12"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="1.2 s" Padding="8,4" FontSize="12"/>
          <TextBlock Grid.Row="2" Grid.Column="2" Text="WARN" Padding="8,4" FontSize="12" Foreground="#FFDC781E"/>
        </Grid>
      </Border>
      <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,4"/>
      <TextBlock Text="See https://learn.microsoft.com for more." FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
    </StackPanel>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🛠" FontSize="11"/>
            <TextBlock Text="ChatMarkdownRenderer currently only handles fenced code + paragraphs — feasible but a moderate rendering effort." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.3 Math (LaTeX)" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="$...$ and $$...$$ inline/block math." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
  <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="14,12">
    <StackPanel HorizontalAlignment="Center" Spacing="6">
      <TextBlock TextAlignment="Center"><Run FontSize="24" FontFamily="Cambria Math" Text="E = mc"/><Run FontSize="14" FontFamily="Cambria Math" Text="2"/></TextBlock>
      <TextBlock Text="(LaTeX would render via KaTeX/MathJax in webchat)" FontSize="10" FontStyle="Italic" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextAlignment="Center"/>
    </StackPanel>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Trade-off — needs KaTeX/MathJax in a mini-WebView2 or a server-side rasterizer." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.4 Emoji / Unicode" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Color emoji and Unicode symbols inline." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#3328A050">
        <TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
  <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="12,8">
    <StackPanel Spacing="4">
      <TextBlock FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap" IsTextSelectionEnabled="True" xml:space="preserve">🎉 Done! ✅ All 412 tests passed. Star it ★ if useful.</TextBlock>
      
    </StackPanel>
  </Border>
</Grid>
    </Border>
    
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.5 NO_REPLY sentinel" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Silence sentinel — actually invisible in production." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Center" Margin="0,4">
  <Border CornerRadius="10" Padding="10,3" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
    <TextBlock Text="(silent — NO_REPLY sentinel; no UI rendered)" FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — trivial, just suppress on render." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="1.6 Streaming partial" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Mid-stream output with progress ring." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#3328A050">
        <TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
  <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="12,8">
    <StackPanel Spacing="4">
      <TextBlock FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap" IsTextSelectionEnabled="True" xml:space="preserve">Sure, let me explain. The first thing to note is that…</TextBlock>
      <ProgressRing IsActive="True" Width="12" Height="12"/>
    </StackPanel>
  </Border>
</Grid>
    </Border>
    
  </StackPanel>
</Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
