<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.Library.Cat13FlowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="980" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="13. Flow / Session" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Date separators, read receipts, pinned." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border CornerRadius="10" Padding="8,2" Background="#3328A050"><TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33DC781E"><TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33648CB4"><TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/></Border>
                </StackPanel>
            </StackPanel>
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="13.1 Date separator" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="── Today ── pill." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Center" Margin="0,8">
  <Border Padding="12,3" CornerRadius="12" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
    <TextBlock Text="── Today ──" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — client-side grouping by day." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="13.2 Read / send status" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="✓✓ on user bubble." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Right" Margin="40,4,8,4" MaxWidth="640">
  <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10" Padding="12,8">
    <StackPanel Spacing="2">
      <TextBlock Text="On my way!" Foreground="White"/>
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBlock Grid.Column="1" Text="✓✓ 14:30" FontSize="10" Foreground="#FFE6E6FF"/>
      </Grid>
    </StackPanel>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — depends on channel support." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="13.3 Pinned messages" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Top sticky pinned card." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="#FFDC781E" BorderThickness="0,0,0,2" Padding="14,8">
  <StackPanel Orientation="Horizontal" Spacing="8">
    <TextBlock Text="📌" FontSize="14"/>
    <StackPanel>
      <TextBlock Text="Pinned" FontSize="10" FontWeight="SemiBold" Foreground="#FFDC781E"/>
      <TextBlock Text="Project guidelines — read before contributing" FontSize="13"/>
    </StackPanel>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — pin action + a sticky region in the timeline." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
