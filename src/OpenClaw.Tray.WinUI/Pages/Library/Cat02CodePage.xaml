<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.Library.Cat02CodePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="980" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="2. Code / Technical" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Code blocks, diff, diagrams, charts." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border CornerRadius="10" Padding="8,2" Background="#3328A050"><TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33DC781E"><TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33648CB4"><TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/></Border>
                </StackPanel>
            </StackPanel>
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="2.1 Code block" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Fenced code with language tag and copy button." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33DC781E">
        <TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="#FF1E1E1E" CornerRadius="6" Padding="0" Margin="8,4,40,4">
  <StackPanel>
    <Grid Padding="12,6,8,6" Background="#FF252525">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock Text="python" Foreground="#FF9C9C9C" FontSize="11" FontFamily="Consolas"/>
      <Button Grid.Column="1" Content="📋 Copy" FontSize="11" Padding="8,2" Background="Transparent" BorderBrush="#FF3F3F3F"/>
    </Grid>
    <Border Padding="12,8">
      <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="#FFE6E6E6" xml:space="preserve">def greet(name: str) -&gt; str:<LineBreak/>    return f&quot;Hello, &#x7B;name&#x7D;!&quot;<LineBreak/><LineBreak/>print(greet(&quot;Kenny&quot;))</TextBlock>
    </Border>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🛠" FontSize="11"/>
            <TextBlock Text="Feasible — fenced code already renders; copy button needs Clipboard binding." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="2.2 Diff / Patch" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Unified diff with green/red bands." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33DC781E">
        <TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="#FF1E1E1E" CornerRadius="6" Margin="8,4,40,4">
  <StackPanel>
    <Border Padding="10,3"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#FF9C9C9C" Text="@@ src/Services/Chat/ChatMarkdownRenderer.cs @@"/></Border><Border Background="#33C83232" Padding="10,3"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#FFFFB4B4" Text="- BuildParagraph(text)"/></Border><Border Background="#33C83232" Padding="10,3"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#FFFFB4B4" Text="- return result;"/></Border><Border Background="#3328A050" Padding="10,3"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#FFB4FFC8" Text="+ if (lang == &quot;diff&quot;) return BuildDiff(text);"/></Border><Border Background="#3328A050" Padding="10,3"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#FFB4FFC8" Text="+ return BuildParagraph(text);"/></Border>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🛠" FontSize="11"/>
            <TextBlock Text="Feasible — extend ChatMarkdownRenderer to recognise ```diff fences." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="2.3 Mermaid / diagram" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Flowcharts, sequence diagrams, etc." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="#FF1E1E1E" CornerRadius="6" Margin="8,4,40,4" Padding="20" HorizontalAlignment="Left">
  <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
    <Border Background="#FF648CB4" CornerRadius="6" Padding="12,8"><TextBlock Text="A" FontWeight="Bold" Foreground="White"/></Border>
    <TextBlock Text="→" FontSize="20" Foreground="#FF888888" VerticalAlignment="Center"/>
    <Border Background="#FF28A050" CornerRadius="6" Padding="12,8"><TextBlock Text="B" FontWeight="Bold" Foreground="White"/></Border>
    <TextBlock Text="→" FontSize="20" Foreground="#FF888888" VerticalAlignment="Center"/>
    <Border Background="#FFDC781E" CornerRadius="6" Padding="12,8"><TextBlock Text="C" FontWeight="Bold" Foreground="White"/></Border>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Trade-off — needs mini-WebView2 + mermaid.js or pre-rendered SVG." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="2.4 Chart / data viz" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="Bar / line / area charts." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Margin="8,4,40,4" Padding="14" HorizontalAlignment="Left">
  <StackPanel Spacing="6">
    <TextBlock Text="Requests per hour" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom" Height="80">
      <Rectangle Width="20" Height="40" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="60" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="50" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="75" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="35" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="55" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
      <Rectangle Width="20" Height="68" Fill="#FF648CB4" VerticalAlignment="Bottom"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="6">
      <TextBlock Text="Mon" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Tue" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Wed" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Thu" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Fri" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Sat" FontSize="10" Width="20" TextAlignment="Center"/>
      <TextBlock Text="Sun" FontSize="10" Width="20" TextAlignment="Center"/>
    </StackPanel>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Large — needs a structured chart event protocol plus a charting control." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
