<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.Library.Cat12InputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="980" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="12. Input side" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Slash commands, edit marker." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Border CornerRadius="10" Padding="8,2" Background="#3328A050"><TextBlock Text="Implemented" FontSize="10" Foreground="#FF28A050" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33DC781E"><TextBlock Text="Render gap" FontSize="10" Foreground="#FFDC781E" FontWeight="SemiBold"/></Border>
                    <Border CornerRadius="10" Padding="8,2" Background="#33648CB4"><TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/></Border>
                </StackPanel>
            </StackPanel>
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="12.1 Slash commands" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="/reasoning, /approve, /help dropdown." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0" HorizontalAlignment="Stretch" MaxWidth="420">
  <StackPanel>
    <Border Padding="10,6" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
      <TextBlock Text="/_" FontFamily="Consolas" FontSize="13"/>
    </Border>
    <StackPanel Padding="4">
      <Border Padding="10,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <TextBlock Text="/reasoning" FontFamily="Consolas" FontSize="12"/>
          <TextBlock Grid.Column="1" Text="toggle reasoning stream" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
      </Border>
      <Border Padding="10,6" CornerRadius="4">
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <TextBlock Text="/approve" FontFamily="Consolas" FontSize="12"/>
          <TextBlock Grid.Column="1" Text="approve a tool call" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
      </Border>
      <Border Padding="10,6" CornerRadius="4">
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <TextBlock Text="/help" FontFamily="Consolas" FontSize="12"/>
          <TextBlock Grid.Column="1" Text="show available commands" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
      </Border>
    </StackPanel>
  </StackPanel>
</Border>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — autocomplete list in the composer." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
  <StackPanel Spacing="10">
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="12.2 Edited message marker" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
        <TextBlock Text="(edited) indicator." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>
      <Border Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0" CornerRadius="10" Padding="8,2" Background="#33648CB4">
        <TextBlock Text="Future" FontSize="10" Foreground="#FF648CB4" FontWeight="SemiBold"/>
      </Border>
    </Grid>
    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" CornerRadius="6" Padding="6">
      <Grid HorizontalAlignment="Right" Margin="40,4,8,4" MaxWidth="640">
  <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10" Padding="12,8">
    <StackPanel Spacing="2">
      <TextBlock Text="Let's ship the v2 release on Friday." Foreground="White" TextWrapping="Wrap"/>
      <TextBlock Text="(edited)" FontSize="10" Foreground="#FFE6E6FF" FontStyle="Italic"/>
    </StackPanel>
  </Border>
</Grid>
    </Border>
    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" CornerRadius="4" Padding="8,5" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🔮" FontSize="11"/>
            <TextBlock Text="Feasible — store edit history; render label." FontSize="11" FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
  </StackPanel>
</Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
