<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Controls.AgentRunCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid HorizontalAlignment="Left" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Width="28" Height="28"
                CornerRadius="14"
                VerticalAlignment="Top"
                Margin="0,2,0,0">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/Preview/claw.png" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <Border Grid.Column="1"
                MaxWidth="420"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="14,12,14,14">
            <StackPanel Spacing="10">
                <!-- Header -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock x:Name="TitleText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ModelText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="StatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Top">
                        <TextBlock x:Name="TimestampText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Ellipse x:Name="StatusDot"
                                 Width="8" Height="8"
                                 Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Running steps -->
                <Border x:Name="RunningStepsBox"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="12,10,12,10">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Get desktop path"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ProgressRing Grid.Column="0" Width="16" Height="16" IsActive="True"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Grid.Column="1" Text="Scan desktop items"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE823;"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Analyze and present plan"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Completed steps -->
                <Border x:Name="CompletedStepsBox"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Padding="12,10,12,10"
                        Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Scan recent updates and key decisions"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Summarize deltas, blockers, and open items"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Produce concise sync-up brief for you"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Completed actions -->
                <Grid x:Name="CompletedActions" Visibility="Collapsed" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13"/>
                            <TextBlock Text="Open all"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE70F;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13"/>
                            <TextBlock Text="Edit"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource AccentButtonStyle}" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13"/>
                            <TextBlock Text="Retry"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
