<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Controls.NativeChatSurface"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:OpenClawTray.Controls">

    <controls:ChatShell x:Name="Shell" IsComposerVisible="True" IsHeaderVisible="False">
        <controls:ChatShell.ThreadContent>
            <Grid>
                <controls:NativeChatThread x:Name="Thread"/>

                <!-- Connection-state banner overlay (Wave 5). -->
                <Border x:Name="ConnectionBanner" Visibility="Collapsed"
                        VerticalAlignment="Top" HorizontalAlignment="Stretch"
                        Background="#FF332B1E" BorderBrush="#FFDC781E" BorderThickness="0,0,0,1"
                        Padding="12,6,12,6">
                    <TextBlock x:Name="ConnectionBannerText" Foreground="#FFFFE0B4" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Empty placeholder until Initialize is called -->
                <StackPanel x:Name="PlaceholderPanel"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                    <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Connect to gateway to start chatting"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Native chat surface — no WebView2."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </controls:ChatShell.ThreadContent>
    </controls:ChatShell>
</UserControl>
