<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Controls.ChatShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
        <Grid ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftRailColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left rail (collapsible via hamburger) -->
            <Border x:Name="LeftRail"
                    Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Conversations" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="8,6">
                        <TextBlock Text="+ New chat" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </Border>
                    <StackPanel Spacing="6">
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Refactor tray icons" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Coding · 2m ago" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Onboarding copy" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Writing · yesterday" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Triage inbox" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Research · Mon" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Agents" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="• Coding" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="• Research" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="• Writing" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Center: header + thread + composer -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border x:Name="HeaderBorder" Grid.Row="0"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button Click="OnHamburgerClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8,6"
                                    ToolTipService.ToolTip="Toggle conversations">
                                <FontIcon Glyph="&#xE700;" FontSize="14"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Refresh">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            </Button>
                            <Border Width="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="4,4"/>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Attached context">
                                <FontIcon Glyph="&#xE723;" FontSize="14"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Tools">
                                <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Inspect">
                                <FontIcon Glyph="&#xE721;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Thread slot (consumer-provided) -->
                <ScrollViewer Grid.Row="1" Padding="20,16">
                    <ContentPresenter x:Name="ThreadHost" Content="{x:Bind ThreadContent, Mode=OneWay}"/>
                </ScrollViewer>

                <!-- Composer -->
                <Border x:Name="ComposerBorder" Grid.Row="2"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,12">
                    <StackPanel Spacing="8">
                        <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="10,10" Height="56">
                            <TextBlock Text="Message Assistant (Enter to send)"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Top"/>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4" ToolTipService.ToolTip="Attach">
                                    <FontIcon Glyph="&#xE723;" FontSize="14"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4" ToolTipService.ToolTip="Voice">
                                    <FontIcon Glyph="&#xE720;" FontSize="14"/>
                                </Button>
                                <Border Width="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="4,4"/>
                                <ComboBox SelectedIndex="0" MinWidth="80" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Channel">
                                    <ComboBoxItem Content="main"/>
                                    <ComboBoxItem Content="release"/>
                                    <ComboBoxItem Content="experimental"/>
                                </ComboBox>
                                <ComboBox SelectedIndex="0" MinWidth="140" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Model">
                                    <ComboBoxItem Content="Claude Opus 4.7"/>
                                    <ComboBoxItem Content="GPT-5"/>
                                    <ComboBoxItem Content="Gemini 2.5 Pro"/>
                                </ComboBox>
                                <ComboBox SelectedIndex="0" MinWidth="100" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Reasoning">
                                    <ComboBoxItem Content="Default"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Low"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4">
                                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                </Button>
                                <Button Background="#0078D4" BorderThickness="0" Padding="8,4">
                                    <FontIcon Glyph="&#xE724;" FontSize="14" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
