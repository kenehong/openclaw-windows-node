<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Controls.ChatShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="0"
            CornerRadius="0"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
        <Grid ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftRailColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left rail (collapsible via hamburger) -->
            <Border x:Name="LeftRail"
                    Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Conversations" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="8,6">
                        <TextBlock Text="+ New chat" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </Border>
                    <StackPanel Spacing="6">
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Refactor tray icons" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Coding · 2m ago" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Onboarding copy" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Writing · yesterday" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="Triage inbox" Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="Research · Mon" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Agents" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="• Coding" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="• Research" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="• Writing" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Center: header + thread + composer -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border x:Name="HeaderBorder" Grid.Row="0"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button Click="OnHamburgerClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8,6"
                                    ToolTipService.ToolTip="Toggle conversations">
                                <FontIcon Glyph="&#xE700;" FontSize="14"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Refresh">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            </Button>
                            <Border Width="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="4,4"/>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Attached context">
                                <FontIcon Glyph="&#xE723;" FontSize="14"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Tools">
                                <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6" ToolTipService.ToolTip="Inspect">
                                <FontIcon Glyph="&#xE721;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Thread slot (consumer-provided) -->
                <ContentPresenter Grid.Row="1" x:Name="ThreadHost" Content="{x:Bind ThreadContent, Mode=OneWay}"/>

                <!-- Composer -->
                <Border x:Name="ComposerBorder" Grid.Row="2"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,12">
                    <StackPanel Spacing="8">
                        <!-- Row 1: dropdowns (channel / model / reasoning). On their own row so they never get clipped on narrow popups. -->
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <ComboBox x:Name="ChannelCombo" MinWidth="80" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Channel"
                                      ItemsSource="{x:Bind ChannelOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind SelectedChannel, Mode=TwoWay}"
                                      SelectionChanged="OnChannelChanged"/>
                            <ComboBox x:Name="ModelCombo" MinWidth="140" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Model"
                                      ItemsSource="{x:Bind ModelOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind SelectedModel, Mode=TwoWay}"
                                      SelectionChanged="OnModelChanged"/>
                            <ComboBox x:Name="ReasoningCombo" MinWidth="100" Height="28" FontSize="11" Padding="8,0" ToolTipService.ToolTip="Reasoning"
                                      ItemsSource="{x:Bind ReasoningOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind SelectedReasoning, Mode=TwoWay}"
                                      SelectionChanged="OnReasoningChanged"/>
                        </StackPanel>

                        <!-- Row 2: composer textbox -->
                        <TextBox x:Name="ComposerInput"
                                 PlaceholderText="Message Assistant (Enter to send)"
                                 AcceptsReturn="False"
                                 TextWrapping="Wrap"
                                 MinHeight="56"
                                 KeyDown="OnComposerKeyDown"/>

                        <!-- Row 3: action buttons (attach / voice / more / send), right-aligned. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4" ToolTipService.ToolTip="Attach">
                                    <FontIcon Glyph="&#xE723;" FontSize="14"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4" ToolTipService.ToolTip="Voice">
                                    <FontIcon Glyph="&#xE720;" FontSize="14"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="6,4" ToolTipService.ToolTip="More">
                                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="Top">
                                            <MenuFlyoutItem Text="Add">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE710;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="Scroll to bottom">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE896;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                <Button x:Name="SendButton" Background="#0078D4" BorderThickness="0" Padding="8,4" Click="OnSendClick" ToolTipService.ToolTip="Send">
                                    <FontIcon Glyph="&#xE724;" FontSize="14" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
