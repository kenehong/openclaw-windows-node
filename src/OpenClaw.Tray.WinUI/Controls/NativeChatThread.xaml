<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Controls.NativeChatThread"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chat="using:OpenClawTray.Services.Chat"
    xmlns:controls="using:OpenClawTray.Controls">

    <UserControl.Resources>
        <!-- Per-kind data templates. Selector below picks one. -->

        <DataTemplate x:Key="UserMessageTemplate" x:DataType="chat:UserMessageItem">
            <Grid HorizontalAlignment="Right" Margin="40,4,8,4" MaxWidth="640">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="10" Padding="12,8,12,8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                   Foreground="White"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind IsErrored, Mode=OneWay}"
                                   FontSize="11" Foreground="#FFFFD8D8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" x:DataType="chat:AssistantMessageItem">
            <Grid HorizontalAlignment="Left" Margin="8,4,40,4" MaxWidth="720">
                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="10" Padding="12,8,12,8">
                    <StackPanel Spacing="2">
                        <controls:MarkdownPresenter Source="{x:Bind Text, Mode=OneWay}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ProgressRing IsActive="True" Width="12" Height="12"
                                          Visibility="{x:Bind IsStreaming, Mode=OneWay}"/>
                            <TextBlock Text="aborted" FontSize="11" Foreground="#FFB46464"
                                       Visibility="{x:Bind IsAborted, Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}"
                                       Visibility="{x:Bind IsErrored, Mode=OneWay}"
                                       FontSize="11" Foreground="#FFC83232"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AgentEventCardTemplate" x:DataType="chat:AgentEventCardItem">
            <Border Margin="8,2,40,2" Padding="10,6,10,6" CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Glyph}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Label, Mode=OneWay}"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <Border Grid.Column="2" CornerRadius="10" Padding="6,1,6,1">
                            <Border.Background>
                                <SolidColorBrush Color="{x:Bind chat:NativeChatColors.Parse(PhaseColorHex), Mode=OneWay}"/>
                            </Border.Background>
                            <TextBlock Text="{x:Bind PhaseLabel, Mode=OneWay}"
                                       FontSize="10" Foreground="White"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{x:Bind Detail, Mode=OneWay}"
                               Visibility="{x:Bind Detail, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SystemNoticeTemplate" x:DataType="chat:SystemNoticeItem">
            <Grid HorizontalAlignment="Center" Margin="0,4,0,4">
                <Border Padding="10,4,10,4" CornerRadius="12">
                    <Border.Background>
                        <SolidColorBrush Color="{x:Bind chat:NativeChatColors.Parse(ColorHex)}" Opacity="0.18"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{x:Bind Glyph}" FontSize="12"/>
                        <TextBlock Text="{x:Bind Message}" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ThinkingBlockTemplate" x:DataType="chat:ThinkingBlockItem">
            <Border Margin="8,2,40,2" Padding="10,6,10,6" CornerRadius="8"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                    BorderBrush="#FF648CB4" BorderThickness="1">
                <Expander IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                          Header="🧠 Thinking">
                    <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Expander>
            </Border>
        </DataTemplate>

        <controls:ChatTimelineTemplateSelector x:Key="TimelineSelector"
            UserMessageTemplate="{StaticResource UserMessageTemplate}"
            AssistantMessageTemplate="{StaticResource AssistantMessageTemplate}"
            AgentEventCardTemplate="{StaticResource AgentEventCardTemplate}"
            SystemNoticeTemplate="{StaticResource SystemNoticeTemplate}"
            ThinkingBlockTemplate="{StaticResource ThinkingBlockTemplate}"/>

        <controls:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto" Padding="0,8,0,8">
            <ItemsRepeater x:Name="Repeater" ItemsSource="{x:Bind Source, Mode=OneWay}"
                           ItemTemplate="{StaticResource TimelineSelector}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="Collapsed">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="Native chat ready" Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Type below to start a conversation."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
